# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-pro

# APIMart / Google Flow Music API Configuration
APIMART_API_KEY=your_apimart_api_key_here
APIMART_BASE_URL=https://api.apimart.ai/v1

# YouTube Data API v3 Configuration
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
YOUTUBE_TOKEN_FILE=token.json
YOUTUBE_PRIVACY_STATUS=unlisted

# Output & Template Configuration
TEMPLATES_DIR=templates
OUTPUT_DIR=output
LOGS_DIR=logs
DEFAULT_BACKGROUND_TEMPLATE=templates/sample_background.png

# Schedule Settings (Cron format or interval)
SCHEDULE_INTERVAL_HOURS=24
